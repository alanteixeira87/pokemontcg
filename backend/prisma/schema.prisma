generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collection {
  id        Int      @id @default(autoincrement())
  userId    Int      @default(1) @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String   @map("card_id")
  name      String
  image     String
  set       String
  number    String?
  quantity  Int      @default(1)
  price     Float    @default(0)
  favorite  Boolean  @default(false)
  forTrade  Boolean  @default(false) @map("for_trade")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  variants  CardVariant[]
  tradeCards TradeCard[]

  @@unique([userId, cardId])
  @@index([name])
  @@index([userId])
  @@index([set])
  @@index([number])
  @@index([favorite])
  @@index([forTrade])
  @@map("collection")
}

model WantedCard {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String   @map("card_id")
  name      String
  image     String
  set       String
  setId     String?  @map("set_id")
  number    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, cardId])
  @@index([userId])
  @@index([set])
  @@index([setId])
  @@index([number])
  @@map("wanted_cards")
}

model CardVariant {
  id            Int         @id @default(autoincrement())
  userCardId    Int         @map("user_card_id")
  userCard      Collection  @relation(fields: [userCardId], references: [id], onDelete: Cascade)
  variantType   VariantType @map("variant_type")
  ownedQuantity Int         @default(0) @map("owned_quantity")
  tradeQuantity Int         @default(0) @map("trade_quantity")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([userCardId, variantType])
  @@index([userCardId])
  @@index([variantType])
  @@map("card_variants")
}

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  avatarUrl    String?      @map("avatar_url")
  interests    String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  collection   Collection[]
  sentTrades   Trade[]      @relation("RequesterTrades")
  receivedTrades Trade[]    @relation("ReceiverTrades")
  sentMessages TradeMessage[] @relation("SentTradeMessages")
  receivedMessages TradeMessage[] @relation("ReceivedTradeMessages")
  wantedCards  WantedCard[]

  @@map("users")
}

model Trade {
  id             Int         @id @default(autoincrement())
  requesterId    Int         @map("requester_id")
  receiverId     Int         @map("receiver_id")
  requester      User        @relation("RequesterTrades", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver       User        @relation("ReceiverTrades", fields: [receiverId], references: [id], onDelete: Cascade)
  offeredCards   Json        @map("offered_cards")
  requestedCards Json        @map("requested_cards")
  status         TradeStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  cards          TradeCard[]
  messages       TradeMessage[]

  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
  @@map("trades")
}

model TradeCard {
  id           Int           @id @default(autoincrement())
  tradeId      Int           @map("trade_id")
  trade        Trade         @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  collectionId Int           @map("collection_id")
  collection   Collection    @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  cardId       String        @map("card_id")
  variantType  VariantType   @map("variant_type")
  quantity     Int
  side         TradeCardSide
  name         String
  image        String
  set          String
  number       String?
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([tradeId])
  @@index([collectionId])
  @@index([side])
  @@map("trade_cards")
}

model TradeMessage {
  id         Int      @id @default(autoincrement())
  tradeId    Int      @map("trade_id")
  trade      Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  senderId   Int      @map("sender_id")
  sender     User     @relation("SentTradeMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId Int      @map("receiver_id")
  receiver   User     @relation("ReceivedTradeMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  message    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tradeId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@map("trade_messages")
}

enum TradeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
  REJECTED
  CANCELLED
}

enum VariantType {
  NORMAL
  FOIL
  REVERSE_FOIL
  RARE_ILLUSTRATION
}

enum TradeCardSide {
  OFFERED
  REQUESTED
}
