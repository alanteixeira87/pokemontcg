generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collection {
  id        Int      @id @default(autoincrement())
  userId    Int      @default(1) @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String   @map("card_id")
  name      String
  image     String
  set       String
  number    String?
  quantity  Int      @default(1)
  price     Float    @default(0)
  favorite  Boolean  @default(false)
  forTrade  Boolean  @default(false) @map("for_trade")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, cardId])
  @@index([name])
  @@index([userId])
  @@index([set])
  @@index([number])
  @@index([favorite])
  @@index([forTrade])
  @@map("collection")
}

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  avatarUrl    String?      @map("avatar_url")
  interests    String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  collection   Collection[]
  sentTrades   Trade[]      @relation("RequesterTrades")
  receivedTrades Trade[]    @relation("ReceiverTrades")

  @@map("users")
}

model Trade {
  id             Int         @id @default(autoincrement())
  requesterId    Int         @map("requester_id")
  receiverId     Int         @map("receiver_id")
  requester      User        @relation("RequesterTrades", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver       User        @relation("ReceiverTrades", fields: [receiverId], references: [id], onDelete: Cascade)
  offeredCards   Json        @map("offered_cards")
  requestedCards Json        @map("requested_cards")
  status         TradeStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
  @@map("trades")
}

enum TradeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}
